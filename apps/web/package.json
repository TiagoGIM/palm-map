{
  "name": "@palm-map/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "check:staging-env": "node -e \"if (!process.env.VITE_API_BASE_URL) { console.error('Missing VITE_API_BASE_URL for published web build'); process.exit(1) }\"",
    "build:staging": "pnpm check:staging-env && tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "deploy:preview": "wrangler pages deploy dist --project-name palm-map-web-staging",
    "deploy:staging": "node ./scripts/deploy-staging.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wrangler": "^4.76.0"
  }
}
