{
  "name": "@palm-map/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev worker.ts --local --port 3001",
    "dev:staging": "wrangler dev worker.ts --local --port 3001 --env staging",
    "deploy:staging": "wrangler deploy --env staging",
    "test:plan-trip-validation": "tsx --tsconfig tsconfig.node.json scripts/validate-plan-trip.ts",
    "check:ts": "tsx --tsconfig tsconfig.node.json --check scripts/validate-plan-trip.ts"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsx": "^4.21.0",
    "wrangler": "^4.41.0"
  }
}
