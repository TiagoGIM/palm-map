{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://palm-map.local/schema/recife-v1-document.schema.json",
  "title": "RecifeV1Document",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "city",
    "title",
    "category",
    "region",
    "summary",
    "content",
    "tags",
    "source",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "city": { "type": "string", "const": "Recife" },
    "title": { "type": "string", "minLength": 3 },
    "category": {
      "type": "string",
      "enum": ["attraction", "neighborhood", "food_cafe", "logistics"]
    },
    "region": { "type": "string", "minLength": 2 },
    "summary": { "type": "string", "minLength": 10 },
    "content": { "type": "string", "minLength": 30 },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "source": { "type": "string", "minLength": 3 },
    "updatedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  }
}
